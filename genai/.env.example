# Copy this file to genai/.env and fill in your values
# cp genai/.env.example genai/.env

# OpenAI API key — required for the quiz agent
OPENAI_API_KEY=sk-...

# Path to the FIFA squad stats PDF — used by the enrich ETL step
STATS_PDF=/path/to/statsFifa.pdf

# FastAPI port (default: 8002)
API_PORT=8002
