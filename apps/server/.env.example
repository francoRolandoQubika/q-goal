# Copy this file to .env and fill in real values:
#   cp apps/server/.env.example apps/server/.env

# Auth — generate a secret with: openssl rand -base64 32  (must be at least 32 chars)
BETTER_AUTH_SECRET=replace-with-a-random-32-plus-char-secret
BETTER_AUTH_URL=http://localhost:3000

# CORS — the web app's origin
CORS_ORIGIN=http://localhost:3001

# Google Generative AI (used by the server's AI features); leave blank if unused
GOOGLE_GENERATIVE_AI_API_KEY=

# Google OAuth — create an OAuth 2.0 Client ID in Google Cloud Console.
# Authorized redirect URI to register: ${BETTER_AUTH_URL}/api/auth/callback/google
# e.g. http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database — the bundled Postgres is published on host port 5433 (see README).
# Inside Docker the server reaches it as postgres:5432 (overridden in docker-compose.yml).
DATABASE_URL=postgresql://postgres:password@localhost:5433/q-goal
