      {
        "path": "README.md",
        "heading": "Getting Started",
        "body": "This project uses PostgreSQL with Drizzle ORM. You can run it **fully in Docker**\nor **locally with hot reload**. Both share the dependency and environment setup below.\n\n### Prerequisites\n\n- [Bun](https://bun.sh) (see `packageManager` in `package.json` for the pinned version)\n- [Docker](https://www.docker.com) — required for the Docker workflow, and the easiest way to run Postgres for local development\n- [uv](https://docs.astral.sh/uv/) — only needed to work on the Python projects (`etl`, `genai`)",
        "fenced_blocks": [
          "bun install",
          "cp apps/server/.env.example apps/server/.env\ncp apps/web/.env.example apps/web/.env",
          "openssl rand -base64 32",
          "bun run docker:up      # build + start (web, server, postgres)",
          "bun run db:push",
          "docker compose exec server bun run --filter @q-goal/db db:push",
          "bun run db:start      # docker compose up -d postgres (host port 5433)",
          "bun run db:push",
          "bun run dev           # web + server",
          "uv sync",
          "uv run etl               # -> \"Hello from etl!\"\nuv run genai-api         # Start the GenAI FastAPI server (port 8002)\nuv run genai-pipeline    # Run the WC2026 face-match ETL pipeline",
          "uv add --package etl pandas\nuv add --package genai openai",
          "uv run ruff check --fix\nuv run ruff format"
        ]
      }
    ],
